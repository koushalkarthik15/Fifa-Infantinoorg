# ==========================================
# InfantinoOrg Master Environment Template
# ==========================================
# SAFE TO COMMIT. Contains placeholder values ONLY.
# DO NOT insert real API keys, passwords, or credentials here.
#
# Setup:
#   1. Copy this file to .env (root) for Docker / local full-stack dev
#   2. Copy backend section to backend/.env for backend-only dev
#   3. Populate real values from your secret manager or CI/CD pipeline
#
# Production (CI/CD):
#   Inject secrets as GitHub Actions secrets or Vercel environment variables.
#   Never commit a .env file containing real credentials.

# ------------------------------------------
# Application Core
# ------------------------------------------
PROJECT_NAME="InfantinoOrg API"
ENVIRONMENT=production
NODE_ENV=production
PORT=3000
HOSTNAME="0.0.0.0"

# ------------------------------------------
# Logging & Monitoring
# ------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_REQUEST_LOGGING=true

# ------------------------------------------
# Database Configuration
# ------------------------------------------
# Local SQLite (default for development)
DATABASE_URL=sqlite:///./infantinoorg.db
# Production PostgreSQL (Neon or other):
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ------------------------------------------
# API & Network Security
# ------------------------------------------
# CORS_ORIGINS: Required. Must be explicitly set in all environments.
# The application defaults to an empty list (safe — denies all cross-origin
# requests) if this variable is not set.
# Format: JSON array of allowed origins.
# Local:      CORS_ORIGINS=["http://localhost:3000"]
# Production: CORS_ORIGINS=["https://infantino.org","https://www.infantino.org"]
CORS_ORIGINS=["http://localhost:3000"]

NEXT_PUBLIC_API_URL=http://localhost:8000
EXTERNAL_SERVICE_TIMEOUT_SECONDS=15

# ------------------------------------------
# Feature Flags (Opt-in functionality)
# ------------------------------------------
# Default to false. Set to true only when the corresponding API key is set.
ENABLE_GEMINI=false
ENABLE_MAPS=false
ENABLE_FIREBASE=false

# ------------------------------------------
# Google Gemini (AI Provider)
# ------------------------------------------
# Obtain from: https://aistudio.google.com/app/apikey
# CI/CD: Store as GEMINI_API_KEY secret in GitHub Actions / Vercel
GEMINI_API_KEY=

# ------------------------------------------
# Google Maps Platform (Navigation)
# ------------------------------------------
# Obtain from: https://console.cloud.google.com/google/maps-apis
# CI/CD: Store as GOOGLE_MAPS_API_KEY secret in GitHub Actions / Vercel
GOOGLE_MAPS_API_KEY=

# ------------------------------------------
# Firebase (Authentication)
# ------------------------------------------
# Obtain from: https://console.firebase.google.com/project/{project}/settings/general
# CI/CD: Store as FIREBASE_PROJECT_ID secret in GitHub Actions / Vercel
FIREBASE_PROJECT_ID=your-project-id
# Note: Do NOT commit the Firebase Admin SDK service account JSON file.
# Inject credentials via GOOGLE_APPLICATION_CREDENTIALS env var in production.
