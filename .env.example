# ==========================================
# InfantinoOrg Master Environment Template
# ==========================================
# This file contains ALL configuration variables for both
# Backend and Frontend. 
#
# DO NOT COMMIT SECRETS TO THIS FILE.

# ------------------------------------------
# Application Core
# ------------------------------------------
PROJECT_NAME="InfantinoOrg API"
ENVIRONMENT=production
NODE_ENV=production
PORT=3000
HOSTNAME="0.0.0.0"

# ------------------------------------------
# Logging & Monitoring
# ------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_REQUEST_LOGGING=true

# ------------------------------------------
# Database Configuration
# ------------------------------------------
DATABASE_URL=sqlite:///./infantinoorg.db

# ------------------------------------------
# API & Network Security
# ------------------------------------------
# In production, specify exact frontend domains (e.g. ["https://infantino.org", "http://localhost:3000"])
CORS_ORIGINS=["http://localhost:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000
EXTERNAL_SERVICE_TIMEOUT_SECONDS=15

# ------------------------------------------
# Feature Flags (Opt-in functionality)
# ------------------------------------------
# Default to false to ensure safe fallback behavior if APIs are unconfigured
ENABLE_GEMINI=false
ENABLE_MAPS=false
ENABLE_FIREBASE=false

# ------------------------------------------
# Google Gemini (AI Provider)
# ------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------
# Google Maps Platform (Navigation)
# ------------------------------------------
GOOGLE_MAPS_API_KEY=

# ------------------------------------------
# Firebase (Authentication)
# ------------------------------------------
FIREBASE_PROJECT_ID=your-project-id
